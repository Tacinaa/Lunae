# Base de données
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/lunae?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Chiffrement AES-256 des notes de cycle — générer avec :
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CYCLE_DATA_ENCRYPTION_KEY="change-me-32-bytes-base64-in-production"

# SMTP (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="ton-email@gmail.com"
SMTP_PASS="ton-app-password"
SMTP_FROM="Lunae <noreply@lunae.app>"

# App
PORT=3000
NODE_ENV=development
